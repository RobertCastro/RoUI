  "effects": {
    "$extensions": {
      "org.roui": {
        "cssFile": "effects"
      }
    },
    "border": {
      "$type": "string",
      "$value": "1px solid {colors.ink-10}"
    },
    "border-dashed": {
      "$type": "string",
      "$value": "1px dashed {colors.ink-20}"
    },
    "border-strong": {
      "$type": "string",
      "$value": "1px solid {colors.ink-18}"
    },
    "duration": {
      "$type": "string",
      "$value": "0.15s"
    },
    "ease": {
      "$type": "string",
      "$value": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "ease-out": {
      "$type": "string",
      "$value": "cubic-bezier(0.2, 0.7, 0.2, 1)"
    },
    "focus-ring": {
      "$type": "string",
      "$value": "0 0 0 3px rgba(169, 160, 236, 0.55)"
    },
    "icon-lg": {
      "$type": "string",
      "$value": "20px"
    },
    "icon-md": {
      "$type": "string",
      "$value": "18px"
    },
    "icon-sm": {
      "$type": "string",
      "$value": "16px"
