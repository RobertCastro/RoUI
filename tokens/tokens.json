    },
    "shadow-sm": {
      "$type": "string",
      "$value": "0 1px 2px rgba(23, 23, 25, 0.06)"
    },
    "transition": {
      "$type": "string",
      "$value": "all {effects.duration} {effects.ease}"
    }
