{
  "name": "@robertcastro/roui",
  "version": "1.1.0",
  "description": "RoUI — design system reutilizable: tokens, componentes y layouts en CSS.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RobertCastro/RoUI.git"
  },
  "homepage": "https://github.com/RobertCastro/RoUI#readme",
  "bugs": {
    "url": "https://github.com/RobertCastro/RoUI/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "main": "dist/roui.css",
  "style": "dist/roui.css",
  "exports": {
    ".": "./dist/roui.css",
    "./bundle.css": "./dist/roui.css",
    "./min.css": "./dist/roui.min.css",
    "./tokens.css": "./src/tokens/index.css",
    "./themes.css": "./src/tokens/themes.css",
    "./component-tokens.css": "./src/tokens/components.css",
    "./reset.css": "./src/base/reset.css",
    "./animations.css": "./src/base/animations.css",
    "./components/*.css": "./src/components/*.css",
    "./layouts/*.css": "./src/layouts/*.css",
    "./utilities.css": "./src/utilities/helpers.css",
    "./primitives/overlay-controller": "./dist/primitives/overlay-controller.js",
    "./primitives/disclosure-controller": "./dist/primitives/disclosure-controller.js",
    "./primitives/tabs-controller": "./dist/primitives/tabs-controller.js",
    "./primitives/combobox-controller": "./dist/primitives/combobox-controller.js",
    "./primitives/grid-controller": "./dist/primitives/grid-controller.js",
    "./primitives/toast-controller": "./dist/primitives/toast-controller.js",
    "./icons.svg": "./dist/icons.svg",
    "./tokens.json": "./tokens/tokens.json",
    "./tailwind": "./tokens/tailwind.preset.cjs"
  },
  "files": [
    "dist",
    "src",
    "!src/primitives",
    "!src/icons/icons.json",
    "tokens",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:reference": "node scripts/build-reference.mjs",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version && node scripts/build-reference.mjs",
    "check:reference": "node scripts/build-reference.mjs --check",
    "check:examples": "node scripts/check-examples.mjs",
    "check:tokens": "node scripts/build-tokens.mjs --check",
    "check:contrast": "node scripts/check-contrast.mjs",
    "check:literals": "node scripts/check-literals.mjs",
    "baseline": "node scripts/baseline.mjs",
    "lint": "stylelint \"src/**/*.css\" \"fixtures/**/*.css\"",
    "check:size": "node scripts/check-package-size.mjs",
    "check:axe": "node scripts/check-axe.mjs",
    "test:package": "node scripts/test-package.mjs",
    "test:consumers": "node scripts/test-consumers.mjs",
    "test:primitives": "node --test test/*.test.mjs",
    "test:e2e": "playwright test",
    "test:visual": "playwright test -c playwright.visual.config.mjs",
    "validate": "npm run check:tokens && npm run check:contrast && npm run check:literals && npm run build && npm run lint && npm run baseline && npm run test:primitives && npm run test:package && npm run test:consumers && npm run check:reference && npm run check:examples && npm run check:axe && npm run check:size",
    "prepare": "node scripts/build.mjs",
    "start": "python3 -m http.server 8799",
    "serve": "python3 -m http.server 8799",
    "dev": "node scripts/build.mjs && echo '→ http://localhost:8799/docs/index.html' && python3 -m http.server 8799",
    "release": "npm run build && changeset publish",
    "sbom": "cyclonedx-npm --omit dev --output-format JSON --output-file sbom.json",
    "codemod:legacy-states": "node codemods/legacy-states.mjs"
  },
  "keywords": [
    "design-system",
    "css",
    "tokens",
    "roui",
    "ui"
  ],
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@changesets/cli": "^2.27.11",
    "@cyclonedx/cyclonedx-npm": "^1.19.3",
    "@playwright/test": "^1.49.1",
    "axe-core": "^4.12.1",
    "esbuild": "0.25.0",
    "jsdom": "^25.0.1",
    "marked": "^14.1.3",
    "stylelint": "16.13.0",
    "tailwindcss": "3.4.17"
  }
}
