{
  "name": "drawer",
  "title": "Drawer",
  "group": "Overlays",
  "maturity": "experimental",
  "summary": "Panel deslizante lateral o inferior (off-canvas) para navegación o contenido secundario, modal.",
  "whenToUse": [
    "Menú de navegación en móvil (lateral).",
    "Panel de detalle o filtros que se abre desde un borde (bottom-sheet)."
  ],
  "whenNotToUse": [
    "Para una confirmación puntual: usa Modal.",
    "Para una pista breve: usa Popover o Tooltip."
  ],
  "anatomy": {
    "html": "<button data-ro-overlay-open=\"d1\" aria-haspopup=\"dialog\" aria-controls=\"d1\" aria-expanded=\"false\">Menú</button>\n<div class=\"ro-drawer-root\" id=\"d1\" data-ro-overlay-root hidden>\n  <div class=\"ro-drawer-overlay\" data-ro-overlay-backdrop></div>\n  <aside class=\"ro-drawer ro-drawer--left\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"d1-t\" tabindex=\"-1\">\n    <div class=\"ro-drawer__header\">\n      <h2 class=\"ro-drawer__title\" id=\"d1-t\">Menú</h2>\n      <button class=\"ro-btn-icon\" data-ro-overlay-close aria-label=\"Cerrar\"><svg class=\"ro-icon\" aria-hidden=\"true\"><use href=\"#ro-i-x\"></use></svg></button>\n    </div>\n    <div class=\"ro-drawer__body\">…</div>\n  </aside>\n</div>",
    "notes": [
      "Reutiliza el overlay-controller: mismo contrato que Modal (foco, Escape, restauración).",
      "El backdrop (data-ro-overlay-backdrop) cierra al hacer clic fuera del panel.",
      "El bottom-sheet añade ro-drawer__grip como asa visual."
    ]
  },
  "api": {
    "classes": [
      { "name": "ro-drawer-root", "desc": "Contenedor del overlay (inicia hidden)." },
      { "name": "ro-drawer-overlay", "desc": "Backdrop de fondo." },
      { "name": "ro-drawer", "desc": "Panel deslizante." },
      { "name": "ro-drawer--left", "desc": "Variante lateral izquierda." },
      { "name": "ro-drawer--right", "desc": "Variante lateral derecha." },
      { "name": "ro-drawer--bottom", "desc": "Variante inferior (bottom-sheet)." },
      { "name": "ro-drawer__grip", "desc": "Asa del bottom-sheet." }
    ],
    "data": [
      { "name": "data-ro-overlay-root", "desc": "Contenedor del overlay." },
      { "name": "data-ro-overlay-open", "desc": "Disparador: id del drawer." },
      { "name": "data-ro-overlay-close", "desc": "Control de cierre." },
      { "name": "data-ro-overlay-backdrop", "desc": "Fondo que cierra al hacer clic." }
    ],
    "tokens": ["--ro-radius-2xl", "--ro-shadow-md", "--ro-z-overlay", "--ro-white"],
    "primitive": { "import": "createOverlayController", "module": "overlay-controller" }
  },
  "a11y": {
    "contract": "accessibility/dialog-drawer.md",
    "keyboard": [
      ["Tab / Shift+Tab", "Cicla el foco dentro del panel (trap)."],
      ["Escape", "Cierra el panel y restaura el foco."]
    ],
    "notes": [
      "role=dialog aria-modal=true, igual que Modal.",
      "El backdrop cierra al hacer clic; el foco vuelve al disparador."
    ]
  },
  "examples": [
    {
      "title": "Drawer lateral (interactivo)",
      "html": "<button class=\"ro-btn ro-btn--dark\" data-ro-overlay-open=\"ref-drawer\" aria-haspopup=\"dialog\" aria-controls=\"ref-drawer\" aria-expanded=\"false\">Abrir menú</button>\n<div class=\"ro-drawer-root\" id=\"ref-drawer\" data-ro-overlay-root hidden>\n  <div class=\"ro-drawer-overlay\" data-ro-overlay-backdrop></div>\n  <aside class=\"ro-drawer ro-drawer--left\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"ref-drawer-t\" tabindex=\"-1\">\n    <div class=\"ro-drawer__header\">\n      <h2 class=\"ro-drawer__title\" id=\"ref-drawer-t\">Menú</h2>\n      <button class=\"ro-btn-icon\" data-ro-overlay-close aria-label=\"Cerrar\"><svg class=\"ro-icon\" aria-hidden=\"true\"><use href=\"#ro-i-x\"></use></svg></button>\n    </div>\n    <div class=\"ro-drawer__body\">Contenido del panel lateral.</div>\n  </aside>\n</div>"
    }
  ],
  "dodont": {
    "do": [
      "Usa el lateral para navegación y el inferior para acciones en móvil.",
      "Cierra con Escape, backdrop y botón."
    ],
    "dont": [
      "No pongas flujos largos de varios pasos en un drawer.",
      "No dejes foco alcanzable detrás del panel."
    ]
  },
  "related": ["modal", "menu", "sidebar"]
}
