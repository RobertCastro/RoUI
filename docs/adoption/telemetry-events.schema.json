{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/RobertCastro/RoUI/docs/adoption/telemetry-events.schema.json",
  "title": "RoUI · evento de telemetría de adopción",
  "description": "Esquema de eventos opt-in de adopción. Mide proyectos y equipos, nunca personas ni usuarios finales.",
  "type": "object",
  "required": ["event", "project", "roui_version", "timestamp"],
  "additionalProperties": false,
  "properties": {
    "event": {
      "type": "string",
      "enum": ["adoption_started", "component_used", "primitive_used", "migration_run", "version_upgraded"]
    },
    "project": {
      "type": "string",
      "description": "Identificador del proyecto consumidor (no del usuario)."
    },
    "roui_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+"
    },
    "component": {
      "type": "string",
      "description": "Nombre del componente (para component_used)."
    },
    "primitive": {
      "type": "string",
      "description": "Nombre de la primitiva (para primitive_used)."
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "from_version": {
      "type": "string",
      "description": "Versión previa (para version_upgraded)."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
